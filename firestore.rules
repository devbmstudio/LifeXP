rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "manebhaskar08@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUserProfile(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'photoURL', 'class', 'level', 'xp', 'gold', 'inventory', 'rank', 'streak', 'lastActive', 'lastNightCheck', 'skills', 'achievements', 'settings', 'role']) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.class in ['Warrior', 'Mage', 'Rogue', 'Paladin'] &&
             data.level is int && data.level >= 1 &&
             data.xp is int && data.xp >= 0 &&
             (!('gold' in data) || data.gold is int) &&
             data.streak is int && data.streak >= 0 &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('lastActive' in data) || data.lastActive is string) &&
             (!('lastNightCheck' in data) || data.lastNightCheck is string);
    }

    function isValidHabit(data) {
      return hasOnlyAllowedFields(['id', 'name', 'category', 'difficulty', 'streak', 'lastCompleted']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.category is string &&
             data.difficulty in ['Normal', 'Hard', 'Legendary'] &&
             data.streak is int && data.streak >= 0;
    }

    function isValidGoal(data) {
      return hasOnlyAllowedFields(['id', 'name', 'category', 'progress', 'deadline', 'rewards']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.progress is int && data.progress >= 0 && data.progress <= 100;
    }

    function isValidSkill(data) {
      return hasOnlyAllowedFields(['name', 'level', 'xp', 'maxXp', 'emoji', 'category']) &&
             data.name is string && data.level is int && data.xp is int;
    }

    function isValidReminder(data) {
      return hasOnlyAllowedFields(['id', 'title', 'note', 'priority', 'triggerDate', 'repeat', 'imageUrl', 'dismissed']) &&
             data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.priority in ['Urgent', 'Normal', 'Soft'] &&
             data.dismissed is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());

      match /habits/{habitId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHabit(request.resource.data);
        allow update: if isOwner(userId) && isValidHabit(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGoal(request.resource.data);
        allow update: if isOwner(userId) && isValidGoal(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /skills/{skillId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSkill(request.resource.data);
        allow update: if isOwner(userId) && isValidSkill(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /reminders/{reminderId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReminder(request.resource.data);
        allow update: if isOwner(userId) && isValidReminder(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
